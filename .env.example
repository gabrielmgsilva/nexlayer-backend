# ─── Banco de dados ───────────────────────────────────────────────
DATABASE_URL="postgresql://criaforma:criaforma@localhost:5432/criaforma_db"

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET="troque_por_uma_string_secreta_forte"
JWT_REFRESH_SECRET="troque_por_outra_string_secreta_forte"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Aplicação ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────
# Lista separada por vírgula. Use * para permitir qualquer origem (dev).
CORS_ORIGIN="http://localhost:5173,http://localhost:3001"

# ─── Upload de arquivos ───────────────────────────────────────────
UPLOAD_DEST="./uploads"
MAX_FILE_SIZE_MB=50

# ─── Cloudflare R2 (armazenamento de arquivos) ────────────────────
# Crie um bucket no Cloudflare R2 e gere as credenciais de API.
# R2_PUBLIC_URL: URL pública do bucket (domínio customizado ou *.r2.dev)
R2_ACCOUNT_ID="seu-cloudflare-account-id"
R2_ACCESS_KEY_ID="seu-r2-access-key-id"
R2_SECRET_ACCESS_KEY="seu-r2-secret-access-key"
R2_BUCKET_NAME="criaforma-files"
R2_PUBLIC_URL="https://files.seudominio.com"
